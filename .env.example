# Google Service Account credentials
# Get these from Google Cloud Console > IAM & Admin > Service Accounts
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Copy the private key from your service account JSON key file.
# Keep the quotes. The \n characters represent real newlines in the key.
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQ...\n-----END RSA PRIVATE KEY-----"

# The ID found in the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# CloudHub backend URL used by the landing site server routes
CLOUDHUB_API_URL=http://159.69.240.210:5021
PUBLIC_MENU_BRANCH_ID=1

# Firebase Web App config for Google sign-in
# Derived from: C:\Users\User\Downloads\arzzon-5e5d0-firebase-adminsdk-fbsvc-6f8ecaace3.json
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=arzzon-5e5d0.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=arzzon-5e5d0

# These three values are not present in the Firebase Admin SDK JSON.
# Copy them from Firebase Console > Project settings > General > Your apps > Web app.
NEXT_PUBLIC_FIREBASE_API_KEY=replace_with_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_APP_ID=replace_with_firebase_web_app_id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=replace_with_firebase_sender_id
